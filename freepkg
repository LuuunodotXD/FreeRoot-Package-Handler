#!/bin/sh
set -e

REPO="https://raw.githubusercontent.com/LuuunodotXD/FreeRoot-Package-Handler/main/packages"
REPO_INDEX="https://raw.githubusercontent.com/LuuunodotXD/FreeRoot-Package-Handler/main/db/amd64.index"
PKG_DB="/var/lib/pkgm/installed"
PKG_CACHE="/var/cache/pkgm"

mkdir -p "$PKG_DB" "$PKG_CACHE"

install_pkg() {
    if is_installed "$1"; then
        echo "==> $1 is already installed."
        return 0
    fi

    echo "==> Searching info about $1..."
    curl -fsSL "$REPO/$1/PKGINFO" -o "/tmp/pkginfo_$1" || {
        echo "ERROR: package '$1' not found in repository."
        exit 1
    }

    . "/tmp/pkginfo_$1"

    for dep in $deps; do
        is_installed "$dep" || install_pkg "$dep"
    done

    . "/tmp/pkginfo_$1"

    echo "==> Downloading $name-$version...  Do not turn off target!"
    curl -fsSL "$url" -o "$PKG_CACHE/$name-$version.tar.gz"

    echo "==> Verifying checksum..."
    echo "$sha256  $PKG_CACHE/$name-$version.tar.gz" | sha256sum -c - || {
        echo "ERROR: checksum is invalid. Aborting."
        exit 1
    }

    echo "==> Installing $name-$version..."
    tar -xzf "$PKG_CACHE/$name-$version.tar.gz" -C /

    # salva manifesto dos arquivos instalados
    tar -tzf "$PKG_CACHE/$name-$version.tar.gz" > "$PKG_DB/$name.files"

    echo "$name=$version" > "$PKG_DB/$name"
    echo "==> $name-$version installed sucessfully."
}

remove_pkg() {
    is_installed "$1" || { echo "==> $1 is not installed."; exit 1; }

    echo "==> Removing $1..."

    if [ -f "$PKG_DB/$1.files" ]; then
        while read -r file; do
            case "$file" in
                */) continue ;;
            esac
            rm -f "/$file"
        done < "$PKG_DB/$1.files"
        rm -f "$PKG_DB/$1.files"
    else
        echo "==> WARNING: no file manifest found, only removing from database."
    fi

    rm -f "$PKG_DB/$1"
    echo "==> $1 removed sucessfully."
}

search_pkg() {
    echo "==> Fetching package index..."
    curl -fsSL "$REPO_INDEX" -o /tmp/freepkg.index || {
        echo "ERROR: could not fetch package index."
        exit 1
    }

    if [ -z "$1" ]; then
        # sem argumento — lista tudo
        grep -v "^#" /tmp/freepkg.index | while IFS="|" read -r name version desc deps; do
            echo "  $name ($version) - $desc"
        done
    else
        # busca pelo termo
        result=$(grep -i "^$1|" /tmp/freepkg.index)
        if [ -z "$result" ]; then
            echo "==> No packages found for '$1'."
        else
            echo "$result" | while IFS="|" read -r name version desc deps; do
                echo "  $name ($version) - $desc"
                [ -n "$deps" ] && echo "  deps: $deps"
                is_installed "$name" && echo "  [installed]"
            done
        fi
    fi
}

is_installed() {
    [ -f "$PKG_DB/$1" ]
}

list_installed() {
    echo "==> Installed packages:"
    ls "$PKG_DB/" 2>/dev/null | while read -r pkg; do
        case "$pkg" in
            *.files) continue ;;
        esac
        cat "$PKG_DB/$pkg"
    done
}

case "$1" in
    install) install_pkg "$2" ;;
    remove)  remove_pkg  "$2" ;;
    list)    list_installed ;;
    search)  search_pkg  "$2" ;;
    *)
        echo "freepkg - package manager"
        echo "Use: freepkg [install|remove|list|search] <package>"
        ;;
esac
